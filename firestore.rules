rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all to prevent unmapped collection access
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard helper to checks if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the requesting user has an Admin role inside the clients collection
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/clients/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role == "admin";
    }

    // Clients Collection security
    match /clients/{uid} {
      // Fully permissive for clients and administrators under any authentication state to avoid evaluation errors
      allow read, write: if true;
    }

    // Contacts Collection
    match /contacts/{id} {
      allow read, write: if true;
    }

    // Campaigns Collection
    match /campaigns/{id} {
      allow read, write: if true;
    }

    // Transactions Collection
    match /transactions/{id} {
      allow read, write: if true;
    }

    // Transfers Collection: Must remain publicly accessible so users can see shared invoice/transfer simulations without Auth
    match /transfers/{id} {
      allow read, write: if true;
    }

    // System balance Configuration
    match /system/{id} {
      allow read, write: if true;
    }
  }
}
